---
import ChapterLayout from "../layouts/ChapterLayout.astro";
import Divider from "../components/Divider.astro";

const awards = [
  {
    year: "2019",
    title: "Winner of ASA DataFest at UCLA",
    issuer: "American Statistical Association",
    description: "Won the Best Insight Award at UCLA's DataFest for offering the most valuable insight into the sponsor dataset out of the 75 competing teams.",
  },
  {
    year: "2017",
    title: "Regents Scholar",
    issuer: "University of California, Los Angeles",
    description: "Offered to the top 1.5% of incoming students at UCLA based on academic excellence, leadership, and exceptional promise.",
  },
  {
    year: "2017",
    title: "National Merit Scholar",
    issuer: null,
    description: null,
  },
];
---

<ChapterLayout title="Awards" chapter="Chapter IV">
  <p class="drop-cap text-charcoal/80 leading-relaxed mb-10">
    Highlighting a few awards here. Shoutout UCLA for hosting DataFest and would encourage any aspiring Data Scientists to check it out.
  </p>

  <ol class="relative border-l border-gold/30 ml-4">
    {awards.map(({ year, title, issuer, description }, i) => (
      <li class:list={["mb-10 ml-8", i === awards.length - 1 && "mb-0"]}>
        <div class="absolute -left-2.5 w-5 h-5 border-2 border-gold bg-parchment rounded-full" />
        <time class="block font-heading text-gold text-sm tracking-widest mb-1">
          {year}
        </time>
        <h3 class="font-heading text-xl text-burgundy font-semibold mb-1">
          {title}
        </h3>
        {issuer && (
          <p class="text-charcoal/50 text-xs tracking-wide mb-1">{issuer}</p>
        )}
        {description && (
          <p class="text-charcoal/70 text-sm leading-relaxed">{description}</p>
        )}
      </li>
    ))}
  </ol>

  <Divider class="mt-12" />

  <p class="text-center text-charcoal/50 font-heading italic text-sm mt-4">
    Hopefully there are more to come.
  </p>
</ChapterLayout>
