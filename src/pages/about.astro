---
import ChapterLayout from "../layouts/ChapterLayout.astro";
import Divider from "../components/Divider.astro";
import profileImg from "../assets/images/profile.png";
---

<ChapterLayout title="About" chapter="Chapter I">
  <div class="flex flex-col md:flex-row gap-10 items-start mb-12">
    <!-- Profile photo with decorative frame -->
    <div class="shrink-0 mx-auto md:mx-0">
      <div class="w-52 h-64 border-2 border-gold/40 rounded-sm p-1.5 shadow-lg">
        <img
          src={profileImg.src}
          alt="Devyn Fisher"
          class="w-full h-full object-cover rounded-sm"
        />
      </div>
    </div>

    <div>
      <p class="drop-cap text-charcoal/80 leading-relaxed mb-4">
        Devyn Fisher is a Data Scientist who writes for his own entertainment. He lives in San Francisco and enjoys reading fantasy novels, playing soccer, and doing math.
      </p>
    </div>
  </div>

  <Divider />

  <!-- Highlights callout -->
  <div class="mt-8 border border-gold/20 rounded-sm bg-cream/50 p-6">
    <h2 class="font-heading text-xl text-burgundy font-semibold mb-4">Highlights</h2>
    <ul class="space-y-2 text-charcoal/70 text-sm">
      <li class="flex items-baseline gap-3">
        <span class="text-gold">&bull;</span>
        <span>Senior Data Scientist at Databricks</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="text-gold">&bull;</span>
        <span>UCLA graduate with degrees in Mathematics and Statistics</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="text-gold">&bull;</span>
        <span>Sunday league soccer player</span>
      </li>
      <li class="flex items-baseline gap-3">
        <span class="text-gold">&bull;</span>
        <span>Self published novelist</span>
      </li>
    </ul>
  </div>
</ChapterLayout>
