---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href?: string;
  demo?: string;
}

const { title, description, tags, href, demo } = Astro.props;
---

<article class="border border-gold/20 rounded-sm bg-cream/50 p-6 hover:border-gold/40 transition-colors">
  <h3 class="font-heading text-xl text-burgundy font-semibold mb-2">{title}</h3>
  <p class="text-charcoal/70 text-sm leading-relaxed mb-4">{description}</p>
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag) => (
      <span class="text-xs font-body bg-parchment-dark/80 text-charcoal/60 px-2 py-0.5 rounded-sm">
        {tag}
      </span>
    ))}
  </div>
  <div class="flex gap-4">
    {href && (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-heading text-forest hover:text-burgundy transition-colors"
      >
        GitHub &rarr;
      </a>
    )}
    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-heading text-forest hover:text-burgundy transition-colors"
      >
        Live Demo &rarr;
      </a>
    )}
  </div>
</article>
