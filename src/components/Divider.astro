---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class:list={["flex items-center justify-center py-8", className]} role="separator">
  <svg width="280" height="20" viewBox="0 0 280 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-gold/60">
    <line x1="0" y1="10" x2="110" y2="10" stroke="currentColor" stroke-width="1" />
    <path d="M130 2 L140 10 L130 18 L120 10 Z" fill="currentColor" opacity="0.5" />
    <circle cx="140" cy="10" r="3" fill="currentColor" />
    <path d="M150 2 L160 10 L150 18 L140 10 Z" fill="currentColor" opacity="0.5" />
    <line x1="170" y1="10" x2="280" y2="10" stroke="currentColor" stroke-width="1" />
  </svg>
</div>
